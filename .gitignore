# Terraform state files — NEVER commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform variable files with real values
terraform.tfvars
*.auto.tfvars

# Terraform working directories
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Sensitive variable override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Plan output files
*.tfplan

# OS files
.DS_Store
Thumbs.db

# Editor directories
.idea/
.vscode/
*.swp
*.swo
